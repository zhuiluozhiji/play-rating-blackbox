# Copy to .env.local for local runs. Do not commit .env.local.

# Play Console entry point. Prefer a direct content rating questionnaire URL.
PLAY_CONSOLE_URL=https://play.google.com/console/developers
PLAY_APP_ID=
PLAY_PACKAGE_NAME=

# Local runtime paths.
BROWSER_PROFILE_DIR=browser_profile/play-console
COLLECTOR_CONFIG=configs/collector.yaml
MODELING_CONFIG=configs/modeling.yaml

# Optional: override docs/key.md with environment variables.
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
